{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@joinflux/capacitor-sensitive-screen",
  "version": "0.2.0",
  "description": "Capacitor 6 plugin for per-route screen-capture and snapshot protection on Android and iOS.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "JoinfluxCapacitorSensitiveScreen.podspec"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joinflux/capacitor-sensitive-screen.git"
  },
  "author": "Gustavo Hoirisch",
  "bugs": {
    "url": "https://github.com/joinflux/capacitor-sensitive-screen/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "screen-capture",
    "flag-secure",
    "ios-snapshot",
    "privacy"
  ],
  "scripts": {
    "lint": "npm run biome && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run biome:fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "biome": "biome check src",
    "biome:fix": "biome check --write src",
    "prettier": "prettier \"**/*.{css,html,ts,js}\"",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api SensitiveScreenPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/docgen": "^0.2.2",
    "@capacitor/ios": "^6.0.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^1.1.2",
    "prettier": "^3.3.3",
    "prettier-plugin-java": "^2.6.4",
    "rimraf": "^5.0.10",
    "rollup": "^4.21.0",
    "swiftlint": "^1.0.2",
    "typescript": "~5.5.4"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "engines": {
    "node": ">=18.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
